{
  "name": "@ui-builder/builder-core",
  "version": "0.0.1",
  "private": true,
  "description": "Framework-agnostic engine — document model, command system, event bus, plugin engine",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@ui-builder/shared": "workspace:*",
    "@ui-builder/config": "workspace:*",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
