# AI Service Configuration

# Enable AI debug logging
# Set to "true" to see:
# - Incoming requests (prompt, design tokens, components)
# - System prompts sent to LLM
# - User prompts for each section
# - AI responses and parsed commands
# - Design context and decisions
# - Full page mode decisions (node clearing)
# Recommended for development; disable in production
AI_DEBUG=false

# LLM Provider (openai, gemini, claude)
LLM_PROVIDER=claude

# LLM Model name
LLM_MODEL=claude-3-5-sonnet-20241022

# LLM API Key (set in production)
LLM_API_KEY=

# Page generation mode (sequential or parallel)
AI_GENERATION_MODE=sequential

# Batch size for parallel section generation
AI_BATCH_SIZE=3
