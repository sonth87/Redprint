# AI Configuration
# Choose provider: openai | gemini | claude
LLM_PROVIDER=openai
# Choose model for the selected provider
LLM_MODEL=gpt-4o
# Single API key used for the selected provider
LLM_API_KEY=your-api-key-here

# Generation Strategy: parallel | sequential
AI_GENERATION_MODE=sequential
# How many sections to generate in one batch (only for parallel)
AI_BATCH_SIZE=3

# Server Settings
PORT=3002
